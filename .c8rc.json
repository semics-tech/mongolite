{
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "**/*.d.ts",
    "dist/**",
    "node_modules/**",
    "tests/**",
    "examples/**",
    "scripts/**",
    "src/bin/**",
    "src/debugger/**"
  ],
  "all": true,
  "extension": [
    ".ts"
  ],
  "reporter": [
    "text",
    "lcov"
  ],
  "check-coverage": false
}
